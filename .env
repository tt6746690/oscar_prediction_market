# =============================================================================
# API Keys — oscar_prediction_market
# =============================================================================

# TMDb API key — required for building datasets from source
# Get one free at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# OMDb API key — required for building datasets from source
# Get one at https://www.omdbapi.com/apikey.aspx
OMDB_API_KEY=

# Kalshi API auth — required for fetching live market data + trading
# Get API credentials at https://docs.kalshi.com/getting_started/api_keys
# NOT needed for backtesting with cached market data
#
# Kalshi credentials are loaded from FILES (RSA keys belong in files, not env vars).
# 1. Place your API key UUID (one line) in ~/.kalshi_access_key
# 2. Place your RSA private key (PEM format) in ~/.kalshi_private_key
# If your key files are at different paths, update these:
KALSHI_ACCESS_KEY_FILE=~/.kalshi_access_key
KALSHI_PRIVATE_KEY_FILE=~/.kalshi_private_key
